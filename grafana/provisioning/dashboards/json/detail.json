          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    $__timeGroupAlias(o.created_at, '1M'),\n    SUM(oi.quantity * oi.unit_price) as \"CA (€)\",\n    COUNT(DISTINCT o.id) as \"Commandes\"\nFROM orders o\nJOIN customers cu ON o.customer_id = cu.id\nJOIN order_items oi ON oi.order_id = o.id\nWHERE o.status != 'cancelled'\n  AND $__timeFilter(o.created_at)\n  AND cu.country IN (${country:sqlstring})\nGROUP BY 1\nORDER BY 1",
